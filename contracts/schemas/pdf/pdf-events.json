{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "maliev/pdf-events",
    "title": "PDF Service Events",
    "description": "Events published by the PDF Service for document generation",
    "definitions": {
        "PdfGenerationRequestedEvent": {
            "type": "object",
            "description": "Published when async PDF generation is requested",
            "properties": {
                "requestId": {
                    "type": "string",
                    "description": "Unique ID for this PDF generation request (Guid)"
                },
                "referenceId": {
                    "type": "string",
                    "description": "Reference ID of the source document (e.g., invoice ID, receipt ID)"
                },
                "documentType": {
                    "type": "string",
                    "enum": ["Quotation", "Invoice", "Receipt", "Report"],
                    "description": "Type of document being generated"
                },
                "requestedAt": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": ["requestId", "referenceId", "documentType", "requestedAt"]
        },
        "PdfGenerationCompletedEvent": {
            "type": "object",
            "description": "Published when PDF generation completes successfully",
            "properties": {
                "requestId": {
                    "type": "string",
                    "description": "Unique ID for this PDF generation request (Guid)"
                },
                "referenceId": {
                    "type": "string",
                    "description": "Reference ID of the source document"
                },
                "documentType": {
                    "type": "string",
                    "enum": ["Quotation", "Invoice", "Receipt", "Report"],
                    "description": "Type of document that was generated"
                },
                "storageUrl": {
                    "type": "string",
                    "description": "URL where the PDF is stored"
                },
                "completedAt": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": ["requestId", "referenceId", "documentType", "storageUrl", "completedAt"]
        },
        "PdfGenerationFailedEvent": {
            "type": "object",
            "description": "Published when PDF generation fails",
            "properties": {
                "requestId": {
                    "type": "string",
                    "description": "Unique ID for this PDF generation request (Guid)"
                },
                "referenceId": {
                    "type": "string",
                    "description": "Reference ID of the source document"
                },
                "documentType": {
                    "type": "string",
                    "enum": ["Quotation", "Invoice", "Receipt", "Report"],
                    "description": "Type of document that failed to generate"
                },
                "errorMessage": {
                    "type": "string",
                    "description": "Error message describing the failure"
                },
                "failedAt": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": ["requestId", "referenceId", "documentType", "errorMessage", "failedAt"]
        },
        "FinancialReportPdfRequestedEvent": {
            "type": "object",
            "description": "Published when a financial report PDF is requested",
            "properties": {
                "reportId": {
                    "type": "string",
                    "description": "Unique report identifier"
                },
                "reportType": {
                    "type": "string",
                    "description": "Type of financial report"
                },
                "requestedBy": {
                    "type": "string",
                    "description": "User requesting the report"
                },
                "requestedAt": {
                    "type": "string",
                    "format": "date-time",
                    "description": "When the report was requested"
                },
                "periodStart": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Start of reporting period"
                },
                "periodEnd": {
                    "type": "string",
                    "format": "date-time",
                    "description": "End of reporting period"
                },
                "companyName": {
                    "type": "string",
                    "description": "Company name"
                },
                "companyAddress": {
                    "type": "string",
                    "description": "Company address"
                },
                "currency": {
                    "type": "string",
                    "description": "Currency code (e.g., THB)"
                },
                "totalRevenue": {
                    "type": "number",
                    "description": "Total revenue amount"
                },
                "totalExpenses": {
                    "type": "number",
                    "description": "Total expenses amount"
                },
                "netProfit": {
                    "type": "number",
                    "description": "Net profit amount"
                },
                "sections": {
                    "type": "array",
                    "description": "Report sections with line items",
                    "items": {
                        "type": "object",
                        "properties": {
                            "sectionTitle": {
                                "type": "string",
                                "description": "Section title"
                            },
                            "sectionTotal": {
                                "type": "number",
                                "description": "Section total amount"
                            },
                            "lineItems": {
                                "type": "array",
                                "description": "Line items in this section",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "description": {
                                            "type": "string",
                                            "description": "Line item description"
                                        },
                                        "amount": {
                                            "type": "number",
                                            "description": "Line item amount"
                                        },
                                        "isHighlight": {
                                            "type": "boolean",
                                            "description": "Whether this item should be highlighted"
                                        }
                                    },
                                    "required": ["description", "amount"]
                                }
                            }
                        },
                        "required": ["sectionTitle", "sectionTotal"]
                    }
                }
            },
            "required": ["reportId", "requestedBy", "requestedAt"]
        }
    }
}
