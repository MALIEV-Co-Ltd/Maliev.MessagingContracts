{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "maliev/pricing-events",
    "title": "Pricing Domain Events",
    "description": "Events published by the Pricing Service",
    "definitions": {
        "PriceCalculatedEvent": {
            "type": "object",
            "description": "Published when a price calculation for a file analysis completes",
            "properties": {
                "pricingAuditId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Unique identifier for the pricing audit record"
                },
                "quotationId": {
                    "type": ["string", "null"],
                    "format": "uuid",
                    "description": "Quotation ID if this price is linked to a quotation"
                },
                "fileId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Unique identifier for the file"
                },
                "customerId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Unique identifier for the customer"
                },
                "materialId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Material used for pricing calculation"
                },
                "processId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Manufacturing process used for pricing"
                },
                "quantity": {
                    "type": "integer",
                    "description": "Quantity of items priced"
                },
                "inputVolumeCm3": {
                    "type": "number",
                    "description": "Part volume in cm³ used as input"
                },
                "inputSupportVolumeCm3": {
                    "type": "number",
                    "description": "Support material volume in cm³"
                },
                "inputSurfaceAreaCm2": {
                    "type": "number",
                    "description": "Surface area in cm² used as input"
                },
                "strategy": {
                    "type": "string",
                    "description": "Pricing strategy used (e.g. RuleBased, ML)"
                },
                "mlModelVersion": {
                    "type": ["string", "null"],
                    "description": "ML model version used, if applicable"
                },
                "confidenceLevel": {
                    "type": "number",
                    "description": "Confidence level of the price calculation (0-1)"
                },
                "pricingConfigurationId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Pricing configuration record used"
                },
                "breakdown": {
                    "type": "object",
                    "description": "Detailed cost breakdown",
                    "properties": {
                        "materialCost": {
                            "type": "number",
                            "description": "Raw material cost"
                        },
                        "supportCost": {
                            "type": "number",
                            "description": "Support material cost"
                        },
                        "machineTimeCost": {
                            "type": "number",
                            "description": "Machine time cost"
                        },
                        "setupCost": {
                            "type": "number",
                            "description": "Setup cost"
                        },
                        "complexitySurcharge": {
                            "type": "number",
                            "description": "Complexity surcharge"
                        },
                        "subtotalBeforeMargin": {
                            "type": "number",
                            "description": "Subtotal before margin"
                        },
                        "marginAmount": {
                            "type": "number",
                            "description": "Margin amount added"
                        },
                        "totalPrice": {
                            "type": "number",
                            "description": "Total price after margin"
                        }
                    },
                    "required": ["materialCost", "supportCost", "machineTimeCost", "setupCost", "complexitySurcharge", "subtotalBeforeMargin", "marginAmount", "totalPrice"]
                },
                "totalUnitPrice": {
                    "type": "number",
                    "description": "Final calculated unit price"
                },
                "totalPrice": {
                    "type": "number",
                    "description": "Total price including quantity"
                },
                "currency": {
                    "type": "string",
                    "description": "ISO 4217 currency code"
                },
                "validUntil": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Price validity expiry timestamp"
                },
                "calculatedAt": {
                    "type": "string",
                    "format": "date-time",
                    "description": "When the price was calculated"
                },
                "storagePath": {
                    "type": ["string", "null"],
                    "description": "GCS path for frontend join key"
                },
                "estimatedLeadTimeDays": {
                    "type": ["integer", "null"],
                    "description": "Days estimated for production and shipping"
                }
            },
            "required": [
                "pricingAuditId",
                "fileId",
                "customerId",
                "materialId",
                "processId",
                "quantity",
                "inputVolumeCm3",
                "inputSupportVolumeCm3",
                "inputSurfaceAreaCm2",
                "strategy",
                "confidenceLevel",
                "pricingConfigurationId",
                "breakdown",
                "totalUnitPrice",
                "totalPrice",
                "currency",
                "validUntil",
                "calculatedAt"
            ]
        }
    }
}
