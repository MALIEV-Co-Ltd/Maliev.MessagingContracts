{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "maliev/customer-events",
    "title": "Customer Domain Events",
    "description": "Events published by the Customer Service for cross-service integration",
    "definitions": {
        "CustomerCreatedEvent": {
            "type": "object",
            "description": "Published when a new customer is created",
            "properties": {
                "customerId": {
                    "type": "string",
                    "format": "uuid"
                },
                "principalId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "IAM principal ID for the customer"
                },
                "firstName": {
                    "type": "string"
                },
                "lastName": {
                    "type": "string"
                },
                "email": {
                    "type": "string",
                    "format": "email"
                },
                "mobile": {
                    "type": ["string", "null"],
                    "description": "Customer's mobile phone number"
                },
                "extension": {
                    "type": ["string", "null"],
                    "description": "Customer's desk extension for company landline"
                },
                "landline": {
                    "type": ["string", "null"],
                    "description": "Customer's personal or company landline number"
                },
                "segment": {
                    "type": "string",
                    "description": "Customer segment: Retail, Wholesale, Enterprise, Government"
                },
                "tier": {
                    "type": "string",
                    "description": "Customer tier: Bronze, Silver, Gold, Platinum, VIP"
                },
                "companyId": {
                    "type": ["string", "null"],
                    "format": "uuid",
                    "description": "Optional link to Company entity"
                },
                "createdAt": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": ["customerId", "principalId", "firstName", "lastName", "email", "segment", "tier", "createdAt"]
        },
        "CustomerUpdatedEvent": {
            "type": "object",
            "description": "Published when customer information is updated",
            "properties": {
                "customerId": {
                    "type": "string",
                    "format": "uuid"
                },
                "updatedFields": {
                    "type": "object",
                    "description": "Dictionary of changed fields with their new values",
                    "additionalProperties": true
                },
                "updatedBy": {
                    "type": "string",
                    "description": "Actor ID who performed the update"
                },
                "actorType": {
                    "type": "string",
                    "description": "Type of actor: Customer, Employee, System"
                },
                "updatedAt": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": ["customerId", "updatedFields", "updatedBy", "actorType", "updatedAt"]
        },
        "CustomerDeletedEvent": {
            "type": "object",
            "description": "Published when customer is soft-deleted",
            "properties": {
                "customerId": {
                    "type": "string",
                    "format": "uuid"
                },
                "deletedBy": {
                    "type": "string",
                    "description": "Actor ID who performed the deletion"
                },
                "actorType": {
                    "type": "string",
                    "description": "Type of actor: Customer, Employee, System"
                },
                "deletedAt": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": ["customerId", "deletedBy", "actorType", "deletedAt"]
        },
        "CompanyTierChangedEvent": {
            "type": "object",
            "description": "Published by CustomerService when a company's tier is promoted or demoted",
            "properties": {
                "companyId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Unique identifier of the company whose tier changed"
                },
                "previousTier": {
                    "type": "string",
                    "description": "Tier before the change (Classic, Silver, Gold)"
                },
                "newTier": {
                    "type": "string",
                    "description": "Tier after the change (Classic, Silver, Gold)"
                },
                "currentYearPurchaseValue": {
                    "type": "number",
                    "description": "Year-to-date purchase value in THB at the time of the tier change"
                },
                "currentYearOrderCount": {
                    "type": "integer",
                    "description": "Year-to-date order count at the time of the tier change"
                },
                "occurredAt": {
                    "type": "string",
                    "format": "date-time",
                    "description": "UTC timestamp when the tier change occurred"
                }
            },
            "required": ["companyId", "previousTier", "newTier", "currentYearPurchaseValue", "currentYearOrderCount", "occurredAt"]
        }
    }
}
