{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UploadArtifactCommand",
  "type": "object",
  "allOf": [
    {
      "$ref": "../shared/base-message.json"
    },
    {
      "properties": {
        "messageName": {
          "const": "UploadArtifactCommand"
        },
        "messageType": {
          "const": "Command"
        },
        "publishedBy": {
          "const": "GeometryService"
        },
        "consumedBy": {
          "const": [
            "UploadService"
          ]
        }
      }
    }
  ],
  "properties": {
    "payload": {
      "type": "object",
      "properties": {
        "artifactId": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for this artifact"
        },
        "parentUploadId": {
          "type": "string",
          "format": "uuid",
          "description": "The original upload ID this artifact belongs to"
        },
        "storagePath": {
          "type": "string",
          "description": "The target path in GCS (e.g., projects/{projectId}/{filename}_viewer.glb)"
        },
        "contentType": {
          "type": "string",
          "description": "MIME type of the artifact (e.g., model/gltf-binary, image/png)"
        },
        "artifactData": {
          "type": "string",
          "description": "Base64-encoded binary data of the artifact"
        }
      },
      "required": [
        "artifactId",
        "parentUploadId",
        "storagePath",
        "contentType",
        "artifactData"
      ]
    }
  },
  "required": [
    "payload"
  ]
}
