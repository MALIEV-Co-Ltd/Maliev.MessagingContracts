{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "maliev/geometry-events",
    "title": "Geometry Domain Events",
    "description": "Events published by the Geometry Service after 3D file analysis",
    "definitions": {
        "FileAnalyzedEvent": {
            "type": "object",
            "description": "Published when a 3D file analysis completes successfully",
            "properties": {
                "fileId": {
                    "type": "string",
                    "description": "Unique identifier for the file"
                },
                "metrics": {
                    "type": "object",
                    "properties": {
                        "volumeCm3": {
                            "type": "number"
                        },
                        "supportVolumeCm3": {
                            "type": "number"
                        },
                        "surfaceAreaCm2": {
                            "type": "number"
                        },
                        "boundingBox": {
                            "type": "object",
                            "properties": {
                                "x": {
                                    "type": "number"
                                },
                                "y": {
                                    "type": "number"
                                },
                                "z": {
                                    "type": "number"
                                }
                            }
                        },
                        "isManifold": {
                            "type": "boolean"
                        },
                        "triangleCount": {
                            "type": "integer"
                        },
                        "eulerNumber": {
                            "type": "integer"
                        }
                    }
                },
                "glbStoragePath": {
                    "type": ["string", "null"],
                    "description": "GCS storage path of the generated GLB file"
                },
                "thumbnailStoragePath": {
                    "type": ["string", "null"],
                    "description": "GCS storage path of the generated thumbnail image"
                },
                "processedAt": {
                    "type": "string",
                    "format": "date-time"
                },
                "dfmReport": {
                    "type": ["object", "null"],
                    "description": "Optional DFM analysis results. Null if analysis failed or not applicable.",
                    "properties": {
                        "thinWallCount": {
                            "type": "integer",
                            "description": "Number of detected thin-wall regions"
                        },
                        "thinWallRegions": {
                            "type": "array",
                            "description": "Centroid coordinates (mm) of each thin-wall region",
                            "items": {
                                "type": "array",
                                "items": { "type": "number" },
                                "minItems": 3,
                                "maxItems": 3
                            }
                        },
                        "overhangFaceCount": {
                            "type": "integer",
                            "description": "Number of mesh faces with overhang angle > threshold"
                        },
                        "overhangAreaCm2": {
                            "type": "number",
                            "description": "Total projected area (cm²) of overhanging faces"
                        }
                    },
                    "required": ["thinWallCount", "thinWallRegions", "overhangFaceCount", "overhangAreaCm2"]
                }
            },
            "required": [
                "fileId",
                "metrics",
                "processedAt"
            ]
        },
        "FileAnalysisFailedEvent": {
            "type": "object",
            "description": "Published when a 3D file analysis fails",
            "properties": {
                "fileId": {
                    "type": "string",
                    "description": "Unique identifier for the file"
                },
                "errorCode": {
                    "type": "string"
                },
                "details": {
                    "type": [
                        "string",
                        "null"
                    ]
                }
            },
            "required": [
                "fileId",
                "errorCode"
            ]
        }
    }
}
