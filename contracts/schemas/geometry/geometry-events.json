{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "maliev/geometry-events",
    "title": "Geometry Domain Events",
    "description": "Events published by the Geometry Service after 3D file analysis",
    "definitions": {
        "BoundingBox": {
            "type": "object",
            "description": "Bounding box dimensions",
            "properties": {
                "x": {
                    "type": "number"
                },
                "y": {
                    "type": "number"
                },
                "z": {
                    "type": "number"
                }
            }
        },
        "FileMetrics": {
            "type": "object",
            "description": "Geometry metrics for a 3D file",
            "properties": {
                "volumeCm3": {
                    "type": "number"
                },
                "supportVolumeCm3": {
                    "type": "number"
                },
                "surfaceAreaCm2": {
                    "type": "number"
                },
                "boundingBox": {
                    "type": "object",
                    "properties": {
                        "x": {
                            "type": "number"
                        },
                        "y": {
                            "type": "number"
                        },
                        "z": {
                            "type": "number"
                        }
                    }
                },
                "isManifold": {
                    "type": "boolean"
                },
                "triangleCount": {
                    "type": "integer"
                },
                "eulerNumber": {
                    "type": "integer"
                }
            }
        },
        "FileAnalyzedEvent": {
            "type": "object",
            "description": "Published when a 3D file analysis completes successfully",
            "properties": {
                "fileId": {
                    "type": "string",
                    "description": "Unique identifier for the file"
                },
                "customerId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Unique identifier for the customer who uploaded the file"
                },
                "metrics": {
                    "type": "object",
                    "description": "Geometry metrics for the analyzed file",
                    "properties": {
                        "volumeCm3": {
                            "type": "number"
                        },
                        "supportVolumeCm3": {
                            "type": "number"
                        },
                        "surfaceAreaCm2": {
                            "type": "number"
                        },
                        "boundingBox": {
                            "type": "object",
                            "properties": {
                                "x": {
                                    "type": "number"
                                },
                                "y": {
                                    "type": "number"
                                },
                                "z": {
                                    "type": "number"
                                }
                            }
                        },
                        "isManifold": {
                            "type": "boolean"
                        },
                        "triangleCount": {
                            "type": "integer"
                        },
                        "eulerNumber": {
                            "type": "integer"
                        }
                    }
                },
                "glbStoragePath": {
                    "type": ["string", "null"],
                    "description": "GCS storage path of the generated GLB file"
                },
                "thumbnailStoragePath": {
                    "type": ["string", "null"],
                    "description": "GCS storage path of the generated thumbnail image"
                },
                "storagePath": {
                    "type": "string",
                    "description": "GCS storage path of the original 3D file"
                },
                "processedAt": {
                    "type": "string",
                    "format": "date-time"
                },
                "dfmReport": {
                    "type": ["object", "null"],
                    "description": "Optional DFM analysis results. Null if analysis failed or not applicable. Process-specific report type is determined by manufacturingProcessName.",
                    "oneOf": [
                        { "$ref": "#/definitions/FdmDfmReport" },
                        { "$ref": "#/definitions/SlaDfmReport" },
                        { "$ref": "#/definitions/CncDfmReport" }
                    ]
                },
                "materialId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Unique identifier for the material"
                },
                "materialCode": {
                    "type": "string",
                    "description": "Material code (e.g., 'PLA', 'ABS', 'PETG')"
                },
                "manufacturingProcessId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Unique identifier for the manufacturing process"
                },
                "manufacturingProcessName": {
                    "type": "string",
                    "description": "Manufacturing process name (e.g., 'FDM', 'SLA', 'DLP', 'CNC')"
                }
            },
            "required": [
                "fileId",
                "customerId",
                "metrics",
                "processedAt",
                "materialId",
                "materialCode",
                "manufacturingProcessId",
                "manufacturingProcessName"
            ]
        },
        "FileMetricsReadyEvent": {
            "type": "object",
            "description": "Published immediately after mesh metrics are computed, before preview generation",
            "properties": {
                "fileId": {
                    "type": "string",
                    "description": "Unique identifier for the file"
                },
                "storagePath": {
                    "type": "string",
                    "description": "GCS storage path of the original 3D file"
                },
                "metrics": {
                    "type": "object",
                    "description": "Geometry metrics for the analyzed file",
                    "properties": {
                        "volumeCm3": {
                            "type": "number"
                        },
                        "supportVolumeCm3": {
                            "type": "number"
                        },
                        "surfaceAreaCm2": {
                            "type": "number"
                        },
                        "boundingBox": {
                            "type": "object",
                            "properties": {
                                "x": {
                                    "type": "number"
                                },
                                "y": {
                                    "type": "number"
                                },
                                "z": {
                                    "type": "number"
                                }
                            }
                        },
                        "isManifold": {
                            "type": "boolean"
                        },
                        "triangleCount": {
                            "type": "integer"
                        },
                        "eulerNumber": {
                            "type": "integer"
                        }
                    }
                },
                "processedAt": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": ["fileId", "storagePath", "metrics", "processedAt"]
        },
        "SmallThumbnailReadyEvent": {
            "type": "object",
            "description": "Published when the 256px isometric thumbnail is ready for fast frontend delivery",
            "properties": {
                "fileId": {
                    "type": "string",
                    "description": "Unique identifier for the file"
                },
                "storagePath": {
                    "type": "string",
                    "description": "GCS storage path of the original 3D file"
                },
                "thumbnailStoragePath": {
                    "type": "string",
                    "description": "GCS path of the generated 256px isometric WebP thumbnail"
                }
            },
            "required": ["fileId", "storagePath", "thumbnailStoragePath"]
        },
        "FileAnalysisFailedEvent": {
            "type": "object",
            "description": "Published when a 3D file analysis fails",
            "properties": {
                "fileId": {
                    "type": "string",
                    "description": "Unique identifier for the file"
                },
                "storagePath": {
                    "type": "string",
                    "description": "GCS storage path of the file that failed analysis"
                },
                "errorCode": {
                    "type": "string",
                    "description": "The error Code"
                },
                "details": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "The detail"
                }
            },
            "required": [
                "fileId",
                "storagePath",
                "errorCode"
            ]
        },
        "DfmIssueItem": {
            "type": "object",
            "description": "A single DFM issue with human-readable description and threshold context. Included in each report payload so the frontend displays backend-generated descriptions without duplicating threshold values.",
            "properties": {
                "category": {
                    "type": "string",
                    "description": "Short machine-readable key, e.g. 'thin_wall', 'overhang', 'internal_radius'"
                },
                "severity": {
                    "type": "string",
                    "description": "Issue severity: 'info', 'warning', or 'error'",
                    "enum": ["info", "warning", "error"]
                },
                "title": {
                    "type": "string",
                    "description": "Short human-readable title shown in the overlay panel, e.g. 'Thin Walls (3 regions)'"
                },
                "description": {
                    "type": "string",
                    "description": "Detailed message including measured vs. required values, e.g. '3 wall region(s) below the FDM minimum of 0.8mm'"
                },
                "value": {
                    "type": ["number", "null"],
                    "description": "Measured value for this issue (mm, deg, ratio, etc.)"
                },
                "threshold": {
                    "type": ["number", "null"],
                    "description": "Rule threshold that was violated"
                }
            },
            "required": ["category", "severity", "title", "description"]
        },
        "FdmDfmReport": {
            "type": "object",
            "description": "DFM analysis results specific to FDM 3D printing",
            "properties": {
                "reportType": {
                    "type": "string",
                    "const": "FDM"
                },
                "thinWallCount": {
                    "type": "integer",
                    "description": "Number of detected thin-wall regions (wall thickness < 0.8mm)"
                },
                "thinWallRegions": {
                    "type": "array",
                    "description": "Centroid coordinates (mm) of each thin-wall region",
                    "items": {
                        "type": "array",
                        "items": { "type": "number" },
                        "minItems": 3,
                        "maxItems": 3
                    }
                },
                "overhangFaceCount": {
                    "type": "integer",
                    "description": "Number of mesh faces with overhang angle > 45 degrees from vertical"
                },
                "overhangAreaCm2": {
                    "type": "number",
                    "description": "Total projected area (cm²) of overhanging faces"
                },
                "overhangRegions": {
                    "type": "array",
                    "description": "Centroid coordinates (mm) of each overhang region",
                    "items": {
                        "type": "array",
                        "items": { "type": "number" },
                        "minItems": 3,
                        "maxItems": 3
                    }
                },
                "supportRequired": {
                    "type": "boolean",
                    "description": "True if the model requires support structures"
                },
                "estimatedSupportVolumeCm3": {
                    "type": "number",
                    "description": "Estimated volume of support structures needed"
                },
                "smallDetailCount": {
                    "type": "integer",
                    "description": "Number of small details that may be lost during printing"
                },
                "issues": {
                    "type": "array",
                    "description": "Per-issue details with human-readable descriptions and threshold context. Single source of truth — frontend should prefer these over hardcoded strings.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "category": { "type": "string", "description": "Short machine-readable key, e.g. 'thin_wall', 'overhang'" },
                            "severity": { "type": "string", "description": "Issue severity: info, warning, or error" },
                            "title": { "type": "string", "description": "Short human-readable title, e.g. 'Thin Walls (3 regions)'" },
                            "description": { "type": "string", "description": "Detailed message with measured vs. required values" },
                            "value": { "type": "number", "description": "Measured value for this issue (mm, deg, ratio, etc.)" },
                            "threshold": { "type": "number", "description": "Rule threshold that was violated" }
                        }
                    }
                }
            },
            "required": ["reportType", "thinWallCount", "thinWallRegions", "overhangFaceCount", "overhangAreaCm2", "overhangRegions", "supportRequired"]
        },
        "SlaDfmReport": {
            "type": "object",
            "description": "DFM analysis results specific to SLA/DLP resin printing",
            "properties": {
                "reportType": {
                    "type": "string",
                    "const": "SLA"
                },
                "thinWallCount": {
                    "type": "integer",
                    "description": "Number of detected thin-wall regions"
                },
                "thinWallRegions": {
                    "type": "array",
                    "description": "Centroid coordinates (mm) of each thin-wall region",
                    "items": {
                        "type": "array",
                        "items": { "type": "number" },
                        "minItems": 3,
                        "maxItems": 3
                    }
                },
                "overhangFaceCount": {
                    "type": "integer",
                    "description": "Number of mesh faces with overhang"
                },
                "overhangAreaCm2": {
                    "type": "number",
                    "description": "Total projected area (cm²) of overhanging faces"
                },
                "overhangRegions": {
                    "type": "array",
                    "description": "Centroid coordinates (mm) of each overhang region",
                    "items": {
                        "type": "array",
                        "items": { "type": "number" },
                        "minItems": 3,
                        "maxItems": 3
                    }
                },
                "resinTrappingRisk": {
                    "type": "boolean",
                    "description": "True if there are closed cavities where resin could be trapped"
                },
                "resinTrappingRegions": {
                    "type": "array",
                    "description": "Centroid coordinates (mm) of each resin trapping region",
                    "items": {
                        "type": "array",
                        "items": { "type": "number" },
                        "minItems": 3,
                        "maxItems": 3
                    }
                },
                "suctionRisk": {
                    "type": "boolean",
                    "description": "True if there are regions that could create vacuum suction during peeling"
                },
                "suctionRegions": {
                    "type": "array",
                    "description": "Centroid coordinates (mm) of each suction risk region",
                    "items": {
                        "type": "array",
                        "items": { "type": "number" },
                        "minItems": 3,
                        "maxItems": 3
                    }
                },
                "hollowRegions": {
                    "type": "array",
                    "description": "Centroid coordinates (mm) of hollow regions that may need drainage holes",
                    "items": {
                        "type": "array",
                        "items": { "type": "number" },
                        "minItems": 3,
                        "maxItems": 3
                    }
                },
                "issues": {
                    "type": "array",
                    "description": "Per-issue details with human-readable descriptions and threshold context. Single source of truth — frontend should prefer these over hardcoded strings.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "category": { "type": "string", "description": "Short machine-readable key, e.g. 'thin_wall', 'overhang'" },
                            "severity": { "type": "string", "description": "Issue severity: info, warning, or error" },
                            "title": { "type": "string", "description": "Short human-readable title, e.g. 'Thin Walls (3 regions)'" },
                            "description": { "type": "string", "description": "Detailed message with measured vs. required values" },
                            "value": { "type": "number", "description": "Measured value for this issue (mm, deg, ratio, etc.)" },
                            "threshold": { "type": "number", "description": "Rule threshold that was violated" }
                        }
                    }
                }
            },
            "required": ["reportType", "thinWallCount", "thinWallRegions", "overhangFaceCount", "overhangAreaCm2", "overhangRegions", "resinTrappingRisk", "suctionRisk"]
        },
        "CncDfmReport": {
            "type": "object",
            "description": "DFM analysis results specific to CNC machining",
            "properties": {
                "reportType": {
                    "type": "string",
                    "const": "CNC"
                },
                "sharpCornerCount": {
                    "type": "integer",
                    "description": "Number of sharp corners that could cause tool breakage (radius < 2mm)"
                },
                "sharpCornerRegions": {
                    "type": "array",
                    "description": "Coordinates (mm) of each sharp corner region",
                    "items": {
                        "type": "array",
                        "items": { "type": "number" },
                        "minItems": 3,
                        "maxItems": 3
                    }
                },
                "hasUndercuts": {
                    "type": "boolean",
                    "description": "True if the part has undercut features that require special tooling"
                },
                "undercutRegions": {
                    "type": "array",
                    "description": "Coordinates (mm) of each undercut region",
                    "items": {
                        "type": "array",
                        "items": { "type": "number" },
                        "minItems": 3,
                        "maxItems": 3
                    }
                },
                "hasDrillHoles": {
                    "type": "boolean",
                    "description": "True if the part has tap or cross-drilled holes"
                },
                "drillHoleCount": {
                    "type": "integer",
                    "description": "Number of drill holes detected"
                },
                "requiresEdm": {
                    "type": "boolean",
                    "description": "True if EDM/wirecut is required for complex features"
                },
                "requiresGrinding": {
                    "type": "boolean",
                    "description": "True if grinding is required for flat surfaces"
                },
                "minimumFeatureSizeMm": {
                    "type": "number",
                    "description": "Smallest detectable feature size in mm"
                },
                "issues": {
                    "type": "array",
                    "description": "Per-issue details with human-readable descriptions and threshold context. Single source of truth — frontend should prefer these over hardcoded strings.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "category": { "type": "string", "description": "Short machine-readable key, e.g. 'internal_radius', 'overhang'" },
                            "severity": { "type": "string", "description": "Issue severity: info, warning, or error" },
                            "title": { "type": "string", "description": "Short human-readable title" },
                            "description": { "type": "string", "description": "Detailed message with measured vs. required values" },
                            "value": { "type": "number", "description": "Measured value for this issue (mm, deg, ratio, etc.)" },
                            "threshold": { "type": "number", "description": "Rule threshold that was violated" }
                        }
                    }
                }
            },
            "required": ["reportType", "sharpCornerCount", "sharpCornerRegions", "hasUndercuts", "requiresEdm", "requiresGrinding"]
        },
        "DfmAnalysisReadyEvent": {
            "type": "object",
            "description": "Published when DFM analysis is complete with all three process-specific reports",
            "properties": {
                "fileId": {
                    "type": "string",
                    "description": "Unique identifier for the file"
                },
                "storagePath": {
                    "type": "string",
                    "description": "GCS path, used as join key by frontend"
                },
                "fdmReport": {
                    "oneOf": [
                        { "$ref": "#/definitions/FdmDfmReport" },
                        { "type": "null" }
                    ],
                    "description": "FDM-specific DFM data, or null if not applicable"
                },
                "slaReport": {
                    "oneOf": [
                        { "$ref": "#/definitions/SlaDfmReport" },
                        { "type": "null" }
                    ],
                    "description": "SLA-specific DFM data, or null if not applicable"
                },
                "cncReport": {
                    "oneOf": [
                        { "$ref": "#/definitions/CncDfmReport" },
                        { "type": "null" }
                    ],
                    "description": "CNC-specific DFM data, or null if not applicable"
                },
                "analyzedAt": {
                    "type": "string",
                    "format": "date-time",
                    "description": "When analysis completed"
                },
                "overlayPaths": {
                    "type": "object",
                    "description": "Overlay GLB storage paths keyed by PROCESS__category (e.g. FDM__thin_wall)",
                    "additionalProperties": {
                        "type": "string"
                    }
                }
            },
            "required": ["fileId", "storagePath", "analyzedAt"]
        }
    }
}
