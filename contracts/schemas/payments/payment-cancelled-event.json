{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "PaymentCancelledEvent",
    "description": "Provider-neutral event published when a payment is cancelled before completion.",
    "allOf": [
        {
            "$ref": "../shared/base-message.json"
        }
    ],
    "type": "object",
    "properties": {
        "payload": {
            "type": "object",
            "properties": {
                "transactionId": {
                    "type": "string",
                    "format": "uuid"
                },
                "idempotencyKey": {
                    "type": "string"
                },
                "amount": {
                    "type": "number"
                },
                "currency": {
                    "type": "string"
                },
                "customerId": {
                    "type": "string"
                },
                "orderId": {
                    "type": "string"
                },
                "providerName": {
                    "type": "string"
                },
                "reason": {
                    "type": "string"
                },
                "providerEventCode": {
                    "type": "string"
                },
                "cancelledAt": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": [
                "transactionId",
                "amount",
                "currency",
                "customerId",
                "orderId",
                "providerName",
                "providerEventCode",
                "cancelledAt"
            ]
        }
    },
    "required": [
        "payload"
    ]
}
