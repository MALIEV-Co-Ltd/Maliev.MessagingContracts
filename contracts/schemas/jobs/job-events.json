{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "maliev/job-events",
    "title": "Jobs Domain Events",
    "description": "Events published by the Job Service",
    "definitions": {
        "JobStartedEvent": {
            "type": "object",
            "description": "Published when a production job transitions to InProgress status",
            "properties": {
                "jobId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Unique job identifier"
                },
                "orderId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Parent order identifier"
                },
                "materialId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Material being used (FK to MaterialService)"
                },
                "volumeCm3": {
                    "type": "number",
                    "description": "Part volume in cm³ (used for material consumption estimate)"
                },
                "technology": {
                    "type": "string",
                    "description": "Manufacturing technology: Fdm, Sla, Cnc, Scanning, or Design"
                },
                "assignedMachineId": {
                    "type": "string",
                    "description": "Machine assigned (e.g., PRUSA-01, HAAS-VF2)"
                },
                "startedAt": {
                    "type": "string",
                    "format": "date-time",
                    "description": "UTC timestamp when job started"
                }
            },
            "required": [
                "jobId",
                "orderId",
                "materialId",
                "volumeCm3",
                "technology",
                "assignedMachineId",
                "startedAt"
            ]
        },
        "JobCreatedEvent": {
            "type": "object",
            "description": "Published when a new production job is created in JobService",
            "properties": {
                "jobId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Unique job identifier"
                },
                "orderId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Parent order identifier"
                },
                "orderItemId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Specific order item this job covers"
                },
                "processType": {
                    "type": "string",
                    "description": "Manufacturing process: FDM, SLA, CNC, etc."
                },
                "jobNumber": {
                    "type": "string",
                    "description": "Human-readable job number (e.g. JOB-2026-0001)"
                },
                "createdAt": {
                    "type": "string",
                    "format": "date-time",
                    "description": "UTC timestamp when the job was created"
                }
            },
            "required": ["jobId", "orderId", "orderItemId", "processType", "jobNumber", "createdAt"]
        },
        "JobStatusChangedEvent": {
            "type": "object",
            "description": "Published when a job status changes (e.g., Pending → InProgress → Completed)",
            "properties": {
                "jobId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Unique job identifier"
                },
                "orderId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Parent order identifier"
                },
                "previousStatus": {
                    "type": "string",
                    "description": "Job status before this transition"
                },
                "newStatus": {
                    "type": "string",
                    "description": "Job status after this transition"
                },
                "technology": {
                    "type": "string",
                    "description": "Manufacturing technology: Fdm, Sla, Cnc, Scanning, or Design"
                },
                "assignedMachineId": {
                    "type": ["string", "null"],
                    "description": "Machine assigned to this job, if any (e.g., PRUSA-01, HAAS-VF2)"
                },
                "changedAt": {
                    "type": "string",
                    "format": "date-time",
                    "description": "UTC timestamp when the status changed"
                },
                "changedBy": {
                    "type": "string",
                    "description": "User ID or system identity that triggered the status change"
                }
            },
            "required": [
                "jobId",
                "orderId",
                "previousStatus",
                "newStatus",
                "technology",
                "changedAt",
                "changedBy"
            ]
        }
    }
}
