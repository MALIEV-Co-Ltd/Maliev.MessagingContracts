                "messageName": { "const": "UndoRevokeAccessCommand" },
                "messageType": { "const": "Command" },
                "messageVersion": { "const": "1.0" },
                "publishedBy": { "const": "LifecycleService" },
                "consumedBy": { "const": ["LifecycleService"] },
                "isPublic": { "const": false }
            }
        }
    ],
    "type": "object",
    "properties": {
        "payload": {
            "type": "object",
            "description": "The payload for undoing access revocation.",
            "properties": {
                "employeeId": {
                    "type": "string",
